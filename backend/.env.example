# PartnerHub 后端环境变量模板
# 复制此文件为 .env 并填写真实值
# Example: DATABASE_URL="postgresql://user:password@localhost:5432/partnerhub"

# 数据库连接字符串
# 本地 PostgreSQL: postgresql://postgres:postgres@localhost:5432/partnerhub
# Neon 云数据库: 在 https://console.neon.tech 创建项目后获取
DATABASE_URL=""

# 后端服务端口
PORT=3001

# 前端地址（CORS 白名单）
# 本地: http://localhost:3000
# 线上: 你的 Vercel 域名，如 https://partnerhub.vercel.app
FRONTEND_URL="http://localhost:3000"

# JWT 认证密钥
# 生产环境请修改为强随机值，例如：openssl rand -base64 32
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRATION="24h"
